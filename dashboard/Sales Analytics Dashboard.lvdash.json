{
  "datasets": [
    {
      "name": "89dd3eb5",
      "displayName": "Monthly Sales Trend Query",
      "queryLines": [
        "SELECT\n",
        "  order_year,\n",
        "  order_month,\n",
        " round(total_sales,0)\n",
        "FROM\n",
        "  gold_sales\n",
        "ORDER BY\n",
        "  order_year,\n",
        "  order_month;"
      ],
      "catalog": "workspace",
      "schema": "default"
    },
    {
      "name": "1cbff13a",
      "displayName": "Yearly Sales Analysis",
      "queryLines": [
        "SELECT\r\n",
        "order_year,\r\n",
        "round(SUM(total_sales),0) AS yearly_sales\r\n",
        "FROM gold_sales\r\n",
        "GROUP BY order_year\r\n",
        "ORDER BY order_year;"
      ]
    },
    {
      "name": "22db1579",
      "displayName": "Top Sales Months",
      "queryLines": [
        "SELECT\r\n",
        "order_year,\r\n",
        "order_month,\r\n",
        "round(total_sales,0)\r\n",
        "FROM gold_sales\r\n",
        "ORDER BY total_sales DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "9a51e3f2",
      "displayName": "Average Monthly Sales",
      "queryLines": [
        "SELECT\r\n",
        "round(AVG(total_sales),0) AS avg_monthly_sales\r\n",
        "FROM gold_sales;"
      ]
    },
    {
      "name": "97d9b6be",
      "displayName": "Monthly Growth",
      "queryLines": [
        "SELECT\r\n",
        "order_year,\r\n",
        "order_month,\r\n",
        "round(total_sales,0),\r\n",
        "round(LAG(total_sales) OVER (ORDER BY order_year, order_month),0) AS previous_month_sales,\r\n",
        "round(total_sales - LAG(total_sales) OVER (ORDER BY order_year, order_month),0) AS sales_growth\r\n",
        "FROM gold_sales\r\n",
        "GROUP BY order_year,order_month,total_sales\r\n",
        "ORDER BY order_year,order_month"
      ]
    },
    {
      "name": "296696de",
      "displayName": "Top Performing Products Sales and Order Summary",
      "queryLines": [
        "SELECT\r\n",
        "product_id,\r\n",
        "total_orders,\r\n",
        "ROUND(total_sales,0) AS total_sales,\r\n",
        "ROUND(avg_sales_per_order,0) AS avg_sales_per_order\r\n",
        "FROM feature_product\r\n",
        "ORDER BY total_sales DESC;"
      ]
    },
    {
      "name": "654cf726",
      "displayName": "Top Five Products by Average Sales Value",
      "queryLines": [
        "SELECT\r\n",
        "product_id,\r\n",
        "ROUND(avg_sales_per_order,0) AS avg_sales_per_order\r\n",
        "FROM feature_product\r\n",
        "ORDER BY avg_sales_per_order DESC\r\n",
        "LIMIT 5;"
      ]
    }
  ],
